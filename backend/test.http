### 1. 회원가입 테스트 (일반 아이디 방식)
POST http://localhost:8080/api/students/register
Content-Type: application/json

{
  "loginId": "seongwon123",
  "name": "정성원",
  "password": "password123",
  "major": "IT응용공학과",
  "introduction": "백엔드 개발을 주로 하고, 공공데이터 활용 서비스에 관심이 많습니다.",
  "region": "부산 금정구"
}

### 2. 로그인 테스트 (JWT 토큰 발급 확인)
# @name loginReq
POST http://localhost:8080/api/students/login
Content-Type: application/json

{
  "loginId": "seongwon123",
  "password": "password123"
}

### 3. 내 해시태그 등록/수정 (최대 10개)
PUT http://localhost:8080/api/tags/me
Content-Type: application/json
Authorization: Bearer {{loginReq.response.body}}

{
  "tags": [
    { "category": "기술스택", "name": "Spring" },
    { "category": "기술스택", "name": "React" },
    { "category": "분야", "name": "백엔드" },
    { "category": "관심활동", "name": "공공데이터 활용" },
    { "category": "지역", "name": "부산" }
  ]
}

### 4. 내 해시태그 목록 조회
GET http://localhost:8080/api/tags/me
Authorization: Bearer {{loginReq.response.body}}