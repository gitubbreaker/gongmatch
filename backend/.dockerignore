# =============================================
# 도커 빌드 컨텍스트에서 제외할 파일/폴더
# (도커 내부에서 gradle build를 수행하므로
#  로컬 빌드 결과물과 캐시는 완전히 제외)
# =============================================

# 로컬 Gradle 캐시 및 빌드 결과물 (핵심 제외 대상)
.gradle/
build/

# IDE 설정
.idea/
.vscode/
*.iml

# 불필요한 바이너리/문서
*.pdf
*.html

# Git
.git/
.gitignore
.gitattributes

# 로컬 환경 파일
*.env
.env*
